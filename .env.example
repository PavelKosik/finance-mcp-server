# Copy this file to ".env" and fill in your own values.
# NEVER commit a real .env file — it is git-ignored.

# Path to the SQLite database file.
# If unset, the server uses ./data/finance.db
DATABASE_PATH=./data/finance.db

# --- Optional: external brokerage / exchange integration (sync_brokerage) ---
# These are only needed if you use the sync_brokerage tool. They can also be
# stored in the database via the set_setting tool instead of as env vars.

# Base URL of your brokerage/exchange REST API.
BROKERAGE_BASE_URL=

# API key / token for the brokerage API (Bearer auth in the example client).
BROKERAGE_API_KEY=

# Optional FX rate to convert provider currency into your base currency.
FX_RATE=1.0
